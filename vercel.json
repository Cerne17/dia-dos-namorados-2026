{
  "cleanUrls": true,
  "functions": {
    "api/*.py": {
      "includeFiles": "api/_shared.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/generate-question",
      "destination": "/api/generate-question.py"
    },
    {
      "source": "/api/results",
      "destination": "/api/results.py"
    }
  ]
}
